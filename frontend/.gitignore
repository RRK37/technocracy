# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Character sprites above 300 — keep locally, exclude from repo
public/characters/character_030[1-9]/
public/characters/character_03[1-9][0-9]/
public/characters/character_0[4-9][0-9][0-9]/
public/characters/character_1000/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
